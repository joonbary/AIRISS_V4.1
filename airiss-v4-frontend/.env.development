# AIRISS v4.0 Development Environment Configuration
# 개발 환경용 설정 파일

# API Configuration
REACT_APP_API_URL=http://localhost:8003
REACT_APP_API_TIMEOUT=30000

# WebSocket Configuration
REACT_APP_WS_URL=ws://localhost:8003/ws
REACT_APP_WS_RECONNECT_INTERVAL=3000
REACT_APP_WS_MAX_RECONNECT_ATTEMPTS=10

# Application Configuration
REACT_APP_VERSION=4.0.0
REACT_APP_BUILD_DATE=2025-01-15
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_AI_FEEDBACK=true
REACT_APP_ENABLE_WEBSOCKET=true
REACT_APP_ENABLE_FILE_PREVIEW=true
REACT_APP_ENABLE_ANALYTICS=true

# Upload Configuration
REACT_APP_MAX_FILE_SIZE=104857600
REACT_APP_ALLOWED_FILE_TYPES=.csv,.xls,.xlsx
REACT_APP_CHUNK_SIZE=1048576

# Debug Configuration
REACT_APP_DEBUG_MODE=true
REACT_APP_LOG_LEVEL=debug
REACT_APP_ENABLE_DEV_TOOLS=true

# UI Configuration
REACT_APP_DEFAULT_LANGUAGE=ko
REACT_APP_THEME=light
REACT_APP_DATE_FORMAT=YYYY-MM-DD HH:mm:ss
REACT_APP_NUMBER_FORMAT=ko-KR

# Analytics Configuration
REACT_APP_DEFAULT_SAMPLE_SIZE=25
REACT_APP_MAX_SAMPLE_SIZE=1000
REACT_APP_DEFAULT_ANALYSIS_MODE=hybrid

# OpenAI Configuration (Optional)
# REACT_APP_OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
# REACT_APP_OPENAI_MAX_TOKENS=1200

# Performance Configuration
REACT_APP_POLLING_INTERVAL=3000
REACT_APP_DEBOUNCE_DELAY=300
REACT_APP_CACHE_TTL=300000