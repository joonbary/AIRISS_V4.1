# Production Environment Variables

# Environment
ENVIRONMENT=production

# Security (MUST CHANGE!)
SECRET_KEY=your-very-secure-secret-key-here-at-least-32-characters

# Database
DATABASE_URL=postgresql://airiss_user:secure_password@db.example.com:5432/airiss_v4_prod

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# AI Analysis
OPENAI_API_KEY=your-production-openai-api-key

# Admin User (MUST CHANGE!)
FIRST_SUPERUSER=administrator
FIRST_SUPERUSER_PASSWORD=very-secure-admin-password
FIRST_SUPERUSER_EMAIL=admin@your-company.com

# Logging
LOG_LEVEL=WARNING
LOG_DIR=/var/log/airiss

# CORS (your production domains)
BACKEND_CORS_ORIGINS=https://airiss.your-company.com,https://api.airiss.your-company.com

# SSL/TLS
USE_HTTPS=true
SSL_CERT_FILE=/etc/ssl/certs/airiss.crt
SSL_KEY_FILE=/etc/ssl/private/airiss.key

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_METRICS=true

# Cache (Redis)
REDIS_URL=redis://redis.example.com:6379/0

# Job Queue (Celery)
CELERY_BROKER_URL=redis://redis.example.com:6379/1
CELERY_RESULT_BACKEND=redis://redis.example.com:6379/2