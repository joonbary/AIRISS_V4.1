# AIRISS v4 Environment Configuration - Neon DB Example
OPENAI_API_KEY=your-openai-api-key-here

# Database Configuration
# PostgreSQL (Neon DB)
# 주의: 패스워드에 특수문자가 있는 경우 URL 인코딩 필요
# @ → %40, # → %23, & → %26 등
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD_HERE@ep-summer-surf-a153am7x-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Other configurations
SECRET_KEY=your-secret-key-for-jwt-tokens

# Neon DB 연결 문자열 형식:
# postgresql://[user]:[password]@[host]/[database]?sslmode=require
# 
# 예시:
# - user: neondb_owner
# - password: your-password (특수문자는 URL 인코딩)
# - host: ep-summer-surf-a153am7x-pooler.ap-southeast-1.aws.neon.tech
# - database: neondb