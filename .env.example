# AIRISS v4 Environment Configuration
# Copy this file to .env and update with your actual values

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Model selection (default: gpt-3.5-turbo)
# OPENAI_MODEL=gpt-3.5-turbo

# Optional: Temperature for AI responses (0.0-1.0, default: 0.7)
# OPENAI_TEMPERATURE=0.7

# Database Configuration
# For SQLite (default for development):
DATABASE_URL=sqlite:///./airiss.db

# For PostgreSQL/Neon (production):
# DATABASE_URL=postgresql://username:password@host:5432/database

# Security
JWT_SECRET_KEY=your-secret-key-here
SECRET_KEY=your-secret-key-for-jwt-tokens

# API Configuration
API_PORT=8003
API_HOST=0.0.0.0

# Frontend URL
FRONTEND_URL=http://localhost:3001

# File Upload Settings
# MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
# ALLOWED_EXTENSIONS=.xlsx,.xls,.csv

# Token Expiration
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging Level
# LOG_LEVEL=INFO
