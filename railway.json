{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'pip install openai==1.54.5 && python check_openai.py && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  },
  "env": {
    "PYTHON_VERSION": "3.9",
    "NODE_VERSION": "18"
  }
}